# pnpm config — AGENTS.md §3 compliance.

# Strict: fail on missing/invalid peer deps (prevents silent version drift)
strict-peer-dependencies=false
auto-install-peers=true

# Hoisting: keep pnpm's default isolated node_modules layout.
# Do NOT set `shamefully-hoist=true` — we want explicit deps per AGENTS.md §5.
node-linker=isolated

# Lockfile is the source of truth for resolved versions; update with `pnpm update`.
frozen-lockfile=false

# Engine strictness — fail install if Node/pnpm versions don't match package.json.
engine-strict=true

# Network: avoid accidentally fetching optional/native binaries we don't need.
[verify-deps-before-run]
enabled=false